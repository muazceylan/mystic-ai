{
  "expo": {
    "name": "Mystic AI",
    "slug": "mystic",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mysticai.app",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.mysticai.app.test"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication"
    ],
    "scheme": "mystic-ai",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "ae6fd7e4-2d11-45f8-828c-d916782b852f"
      }
    },
    "owner": "mystic-apis-organization"
  }
}
