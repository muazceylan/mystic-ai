#
# Runtime environment
# dev | stage | prod
EXPO_PUBLIC_APP_ENV=dev

# API base URLs by environment (single-source config in src/config/env.ts)
# Dev defaults are resolved automatically (web/iOS/android/device).
# Set this only when you need to force a specific host.
EXPO_PUBLIC_API_BASE_URL_DEV_OVERRIDE=
EXPO_PUBLIC_API_BASE_URL_STAGE=
EXPO_PUBLIC_API_BASE_URL_PROD=

# Legacy fallback (optional). Prefer *_DEV/STAGE/PROD vars above.
EXPO_PUBLIC_API_BASE_URL=

# Spiritual service optional override (dev auto-resolves host and uses port 8091)
EXPO_PUBLIC_SPIRITUAL_API_URL_OVERRIDE=

# Optional mock toggle (only works in __DEV__ and non-prod env)
EXPO_PUBLIC_USE_MOCK=false

EXPO_PUBLIC_FACEBOOK_APP_ID=123456789012345
# Optional alias used by the app if FACEBOOK_APP_ID is not set
EXPO_PUBLIC_META_APP_ID=123456789012345

# Optional runtime config (currently the share card uses the hardcoded /dl universal link)
EXPO_PUBLIC_UNIVERSAL_DOWNLOAD_URL=https://mysticai.app/dl

# Google Places / Maps (companion add/edit location autocomplete + place details + timezone)
# The app checks EXPO_PUBLIC_GOOGLE_PLACES_API_KEY first, then EXPO_PUBLIC_GOOGLE_MAPS_API_KEY
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# AdMob — App IDs are required at native build time (set in app.config.ts via non-EXPO_PUBLIC vars)
# These are read at build time by the Expo config plugin:
ADMOB_ANDROID_APP_ID=ca-app-pub-2129476568906610~2506472009
ADMOB_IOS_APP_ID=ca-app-pub-2129476568906610~1193390335

# These are read at runtime by the mobile app:
EXPO_PUBLIC_ADMOB_ANDROID_REWARDED_UNIT_ID=ca-app-pub-2129476568906610/2039568147
EXPO_PUBLIC_ADMOB_IOS_REWARDED_UNIT_ID=ca-app-pub-2129476568906610/8618386532
# Set to "true" to force Google test ad units regardless of other config
EXPO_PUBLIC_ADMOB_USE_TEST_IDS=true

# Google OAuth (social login)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Analytics — Amplitude (HTTP API based)
# Provider: 'amplitude' | 'none'. Auto-detected if API key is present.
EXPO_PUBLIC_ANALYTICS_PROVIDER=amplitude
EXPO_PUBLIC_ANALYTICS_API_KEY=
EXPO_PUBLIC_ANALYTICS_ENDPOINT=https://api2.amplitude.com/2/httpapi
EXPO_PUBLIC_ANALYTICS_DEBUG=false

# Firebase Analytics (GA4) — native config files
# Android: google-services.json (already in repo root)
# iOS:     GoogleService-Info.plist (download from Firebase Console and place in repo root)
# No runtime env var needed — Firebase reads native config files automatically.
