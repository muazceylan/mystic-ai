{
  "info": {
    "name": "Mystic AI - Complete API Collection",
    "description": "Mystic AI Mikroservis Ekosistemi - Uçtan Uca API Test Collection\n\nBu collection, Mystic AI ekosistemindeki tüm servisleri test etmek için kullanılır.\n\n**Kullanım:**\n1. Environment'i import edin\n2. '01 - Auth Flow' > 'Register' isteğini çalıştırın\n3. 'Login' isteği otomatik olarak JWT token alacak\n4. Diğer istekleri çalıştırabilirsiniz\n\n**Not:** Vision servisi için coffee.jpg veya palm.jpg dosyalarını Postman'de seçmelisiniz.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Auth Flow",
      "description": "Kullanıcı kayıt ve giriş işlemleri",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{test_username}}\",\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"birthDate\": \"1990-05-15\",\n  \"birthTime\": \"14:30\",\n  \"birthLocation\": \"Istanbul, Turkey\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Response has success message', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.exist;",
                  "});",
                  "",
                  "// Store userId from response if available",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.userId) {",
                  "    pm.environment.set('userId', jsonData.userId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{test_username}}\",\n  \"password\": \"{{test_password}}\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has token', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.token).to.exist;",
                  "    pm.expect(jsonData.token).to.not.be.empty;",
                  "});",
                  "",
                  "pm.test('Response has userId', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.userId).to.exist;",
                  "});",
                  "",
                  "// Store token and userId in environment",
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('jwt_token', jsonData.token);",
                  "pm.environment.set('userId', jsonData.userId);",
                  "",
                  "console.log('JWT Token saved to environment');",
                  "console.log('UserId saved: ' + jsonData.userId);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has username', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.username).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
