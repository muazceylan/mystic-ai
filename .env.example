# ===========================================
# Mystic AI - Environment Variables
# ===========================================
# Copy this file to .env and adjust values

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=mystic
DB_PASSWORD=mystic123

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=mystic
RABBITMQ_PASSWORD=mystic123
RABBITMQ_VHOST=mystic

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=mystic123

# Eureka
EUREKA_URL=http://localhost:8761/eureka/

# Startup orchestration timeouts (seconds)
EUREKA_STARTUP_TIMEOUT_SECONDS=60
AUTH_STARTUP_TIMEOUT_SECONDS=90
GATEWAY_STARTUP_TIMEOUT_SECONDS=90
ASTROLOGY_STARTUP_TIMEOUT_SECONDS=180
NUMEROLOGY_STARTUP_TIMEOUT_SECONDS=120
DREAM_STARTUP_TIMEOUT_SECONDS=120
ORACLE_STARTUP_TIMEOUT_SECONDS=120
NOTIFICATION_STARTUP_TIMEOUT_SECONDS=120
VISION_STARTUP_TIMEOUT_SECONDS=120
SPIRITUAL_STARTUP_TIMEOUT_SECONDS=120

# Keep auth/gateway available even if slower domain services are still booting.
# Set to true only if your environment requires strict full-stack readiness before gateway startup.
WAIT_FOR_OPTIONAL_SERVICES_BEFORE_GATEWAY=false

# JWT
JWT_SECRET=bXlzdGljLWFpLXNlY3JldC1rZXktZm9yLWp3dC10b2tlbi1nZW5lcmF0aW9uLW11c3QtYmUtYXQtbGVhc3QtMjU2LWJpdHM=


CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8090,http://localhost:8500,http://localhost:19000,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:8090,http://127.0.0.1:8500,http://127.0.0.1:19000,http://app.localhost,http://admin.localhost

# Email verification token security
VERIFICATION_TOKEN_PEPPER=change-me-super-secret
VERIFICATION_TOKEN_BYTES=48
VERIFICATION_TOKEN_TTL_HOURS=24
VERIFICATION_RESEND_COOLDOWN_SECONDS=60
VERIFICATION_RESEND_DAILY_LIMIT=5
VERIFICATION_RETRY_MAX_ATTEMPTS=3
VERIFICATION_RETRY_DELAY_SECONDS=30

# Allowed Google OAuth client IDs (comma-separated) for social login token audience check
GOOGLE_ALLOWED_CLIENT_IDS=607073022009-t0nujj22fr6k33tuhdg1eka9n9eq36t5.apps.googleusercontent.com,607073022009-a1r82mu51cetqtsknk5fjf34kau393g9.apps.googleusercontent.com

# AI (for ai-orchestrator service)

OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
API_NINJAS_KEY=your_api_ninjas_key_here
AI_LOCAL_LLM_ENABLED=true
AI_LOCAL_LLM_PROVIDER_TYPE=ollama
AI_LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
AI_LOCAL_LLM_MODEL=gemma3:4b
AI_LOCAL_LLM_CHAT_ENDPOINT=/api/generate
AI_LOCAL_LLM_TIMEOUT_MS=15000
AI_LOCAL_LLM_RETRY=0
AI_LOCAL_LLM_COOLDOWN=30
AI_LOCAL_LLM_TEMPERATURE=0.7
AI_LOCAL_LLM_MAX_OUTPUT_TOKENS=1024

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME="Mystic AI"

ENV=local
API_PUBLIC_URL=http://localhost:8080
APP_PUBLIC_URL=http://localhost:8090
EXPO_PUBLIC_COMPARE_ALLOW_MOCK_FALLBACK=false

# GA4 aggregate export (server-side Measurement Protocol)
# Recommended target: a dedicated GA4 web stream for admin/backoffice snapshots.
AUTH_SERVICE_URL=http://localhost:8081
NOTIFICATION_SERVICE_URL=http://localhost:8088
GA4_EXPORT_ENABLED=false
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
GA4_EXPORT_ENDPOINT=https://www.google-analytics.com/mp/collect
GA4_CLIENT_ID=mystic-admin-server
