REDIS_PORT=6379
REDIS_PASSWORD=mystic123

# Eureka
EUREKA_URL=http://localhost:8761/eureka/

# JWT
JWT_SECRET=bXlzdGljLWFpLXNlY3JldC1rZXktZm9yLWp3dC10b2tlbi1nZW5lcmF0aW9uLW11c3QtYmUtYXQtbGVhc3QtMjU2LWJpdHM=

# Public URLs for email verification
ENV=local
API_PUBLIC_URL=http://localhost:8080
APP_PUBLIC_URL=

# Email verification token security
VERIFICATION_TOKEN_PEPPER=change-me-super-secret
VERIFICATION_TOKEN_BYTES=48
VERIFICATION_TOKEN_TTL_HOURS=24
VERIFICATION_RESEND_COOLDOWN_SECONDS=60
VERIFICATION_RESEND_DAILY_LIMIT=5
VERIFICATION_RETRY_MAX_ATTEMPTS=3
VERIFICATION_RETRY_DELAY_SECONDS=30

# Allowed Google OAuth client IDs (comma-separated) for social login token audience check
GOOGLE_ALLOWED_CLIENT_IDS=607073022009-t0nujj22fr6k33tuhdg1eka9n9eq36t5.apps.googleusercontent.com,607073022009-a1r82mu51cetqtsknk5fjf34kau393g9.apps.googleusercontent.com

# SMTP (MailHog local defaults)
